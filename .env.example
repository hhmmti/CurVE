# CurVE runtime configuration — copy to `.env` and edit to override.
#
# Every variable below is OPTIONAL. Each has a built-in default (shown as the value
# here) equal to the value CurVE used before config was externalized, so leaving a
# variable unset — or having no `.env` at all — reproduces the original behavior
# exactly. Setting a variable overrides only that one pin. `.env` is gitignored and
# never shipped; the company copy runs on these defaults.
#
# Precedence: a real OS environment variable wins over a line in `.env`, which wins
# over the built-in default (see curve/config.py).

# --- AWS / Bedrock ------------------------------------------------------------
# AWS SSO profile used for both Bedrock and Athena (explicit profile → AWS_PROFILE
# env → default credential chain).
CURVE_AWS_PROFILE=roam-ai
# AWS region for Bedrock and Athena.
CURVE_AWS_REGION=us-east-1
# Bedrock model / cross-region inference-profile id passed to Converse.
CURVE_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# Athena query-results S3 bucket (shared by every data module).
CURVE_ATHENA_S3_OUTPUT=s3://esp-athena-results-v2-411237692998/

# --- Athena: preprocessed telemetry + production (curve/data.py) --------------
CURVE_PREPROCESSED_CATALOG=roam_prd_products
CURVE_PREPROCESSED_DATABASE=esp_optimization_v2
CURVE_TELEMETRY_TABLE=esp_telemetry_preprocessed
CURVE_PRODUCTION_TABLE=esp_production_preprocessed

# --- Athena: ML setpoint recommendations (curve/recommendations.py) -----------
# DynamoDB mirror via the Athena connector.
CURVE_REC_CATALOG=roam_prd_ddb
CURVE_REC_DATABASE=default
CURVE_REC_TABLE=esp_setpoint_recommendations_v2

# --- Athena: well configuration (curve/well_catalog.py) -----------------------
CURVE_WELLCFG_CATALOG=roam_prd_ddb
CURVE_WELLCFG_DATABASE=default
CURVE_WELLCFG_TABLE=esp_well_configuration_v2

# --- Athena: RRC well depth (curve/well_depth.py) -----------------------------
CURVE_WELL_DEPTH_CATALOG=roam_dev_products
CURVE_WELL_DEPTH_DATABASE=well_depth_dev
CURVE_WELL_DEPTH_TABLE=rrc_well_depth

# --- Athena: ideal pump catalog (curve/ideal_catalog.py) ----------------------
CURVE_IDEAL_CATALOG_CATALOG=roam_dev_products
CURVE_IDEAL_CATALOG_DATABASE=esp_ideal_pump_dev
CURVE_IDEAL_CATALOG_TABLE=ideal_pump_library_v1

# --- Physics defaults ---------------------------------------------------------
# BEP-tolerance window for catalog narrowing (0.25 = ±25%).
CURVE_DEFAULT_BEP_TOLERANCE=0.25

# --- UI flags -----------------------------------------------------------------
# Streamlit developer panel default. OFF for the company copy; set to true/1/on to
# default the "Developer mode" checkbox on (it stays toggleable per session).
CURVE_DEV_PANEL=false
